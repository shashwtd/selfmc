# Template — actual file with real values is on the droplet at /etc/mc-backup/backup.env
PTERO_URL="https://panel.yourdomain.com"
PTERO_KEY="ptlc_REDACTED_see_droplet"
SERVER_ID="<server-id>"
WORLD_DIR="/var/lib/pterodactyl/volumes/<your-server-uuid>"
