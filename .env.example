# ============================================================
#  .env.example — copy to .env and fill in your values
#  Never commit .env to version control.
# ============================================================

# ── Restic / Google Drive backup ────────────────────────────

# Password used to encrypt the restic repository.
# Store this somewhere safe (password manager). Losing it means losing
# access to all your Drive backups.
RESTIC_PASSWORD="your-restic-encryption-password"

# Restic repository path via rclone. The name after the colon must match
# the remote name you configured in rclone (default: gdrive).
RESTIC_REPOSITORY="rclone:gdrive:minecraft-backups"

# Google Cloud OAuth client credentials. These allow rclone to authenticate
# to Google Drive on your behalf. Create at:
#   console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Enable the Google Drive API and set scope to drive.file.
GOOGLE_OAUTH_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_OAUTH_CLIENT_SECRET="your-client-secret"


# ── Droplet / network ────────────────────────────────────────

# Current droplet IP. Updated automatically by revive.py after each revive.
# Set manually if you created the droplet by hand.
DROPLET_IP="1.2.3.4"

# Full URL of the Pterodactyl panel. Must match the subdomain you configured
# in nginx and Cloudflare (proxied). Used by revive.py to derive the panel
# subdomain for DNS updates.
PANEL_URL="https://panel.yourdomain.com"

# Minecraft server address (the Wings FQDN, not proxied through Cloudflare).
# Used by revive.py to derive the MC subdomain and Cloudflare zone for DNS updates.
SERVER_ADDR="play.yourdomain.com"

# Full UUID of the Pterodactyl server (shown in the panel URL when viewing the server).
SERVER_UUID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# First 8 characters of SERVER_UUID. Used in API calls.
SERVER_ID="xxxxxxxx"


# ── Pterodactyl API ──────────────────────────────────────────

# Pterodactyl client API key. Generate at:
#   panel → Account → API Credentials → Create API Key
# This key can start/stop/restart the server and send console commands.
PTERO_API_KEY="ptlc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"


# ── SSH keys ─────────────────────────────────────────────────

# Path to the passphrase-free SSH key used by hibernate.py / revive.py.
# This key must be registered on your DigitalOcean account.
SSH_KEY_AUTOMATION="~/.ssh/do_minecraft_claude"

# Path to your personal SSH key (passphrase-protected, for interactive use).
SSH_KEY_PERSONAL="~/.ssh/id_ed25519"


# ── API tokens ───────────────────────────────────────────────

# DigitalOcean personal access token with read + write scope.
# Generate at: cloud.digitalocean.com → API → Generate New Token
# This token can create and destroy droplets. Keep it secret.
DO_API_TOKEN="dop_v1_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Cloudflare API token scoped to "Zone:DNS:Edit" for your domain zone only.
# Generate at: dash.cloudflare.com → Profile → API Tokens → Create Token
# Use the "Edit zone DNS" template and restrict it to your specific zone.
CF_API_TOKEN="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
